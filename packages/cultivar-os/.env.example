# Supabase — paste your Project URL and anon key below
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_URL=https://cultivar-os.app
VITE_TAX_RATE=0.0825
VITE_DEMO_NURSERY_ID=a1b2c3d4-0000-0000-0000-000000000001

# API base URL — Railway backend (leave empty for local dev with Vite proxy)
VITE_API_URL=

# QuickBooks Online (OAuth 2.0 — sandbox or production)
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=https://cultivar-os.vercel.app/api/qbo/callback
QBO_ENVIRONMENT=sandbox

# Supabase service key — used by FastAPI backend only, never expose to frontend
SUPABASE_SERVICE_KEY=
